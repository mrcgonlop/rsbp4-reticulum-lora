<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ hostname }} services</title>
<style>
  :root { color-scheme: light dark; }
  body {
    font-family: ui-sans-serif, system-ui, sans-serif;
    max-width: 720px;
    margin: 2rem auto;
    padding: 0 1rem;
    line-height: 1.5;
  }
  h1 { margin-bottom: 0.25rem; }
  h1 + p { color: #888; margin-top: 0; }
  table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; }
  th, td { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #8884; }
  th { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: #888; }
  td a { color: inherit; }
  td.proto { color: #888; font-size: 0.85rem; }
  td.port { font-family: ui-monospace, monospace; color: #888; font-size: 0.85rem; }
  .ok { color: #2a8; }
  .off { color: #888; text-decoration: line-through; }
  footer { margin-top: 2rem; color: #888; font-size: 0.85rem; }
</style>
</head>
<body>
<h1>{{ hostname }}</h1>
<p>Service directory · {{ ansible_default_ipv4.address }} · {{ domain }}</p>

<table>
<thead>
<tr><th>Service</th><th>URL</th><th>Port</th></tr>
</thead>
<tbody>
<tr>
  <td>Cockpit <span class="ok">●</span></td>
  <td><a href="https://{{ ansible_default_ipv4.address }}/">https://{{ ansible_default_ipv4.address }}/</a></td>
  <td class="port">443 → 9090</td>
</tr>
<tr>
  <td>Gitea <span class="ok">●</span></td>
  <td><a href="https://{{ ansible_default_ipv4.address }}/gitea/">https://{{ ansible_default_ipv4.address }}/gitea/</a></td>
  <td class="port">443 → {{ gitea_http_port }}</td>
</tr>
{% if meshchat_enable | bool %}
<tr>
  <td>Reticulum MeshChat <span class="ok">●</span></td>
  <td><a href="https://{{ ansible_default_ipv4.address }}:{{ meshchat_nginx_port }}/">https://{{ ansible_default_ipv4.address }}:{{ meshchat_nginx_port }}/</a></td>
  <td class="port">{{ meshchat_nginx_port }} → {{ meshchat_internal_port }}</td>
</tr>
{% endif %}
{% if meshtastic_enable | bool %}
<tr>
  <td>Meshtastic Web <span class="ok">●</span></td>
  <td><a href="https://{{ ansible_default_ipv4.address }}:{{ meshtastic_nginx_port }}/">https://{{ ansible_default_ipv4.address }}:{{ meshtastic_nginx_port }}/</a></td>
  <td class="port">{{ meshtastic_nginx_port }} → {{ meshtastic_web_port }}</td>
</tr>
{% else %}
<tr>
  <td class="off">Meshtastic Web</td>
  <td class="off">disabled (set meshtastic_enable: true)</td>
  <td class="port">—</td>
</tr>
{% endif %}
<tr>
  <td>Reticulum TCP</td>
  <td>tcp://{{ ansible_default_ipv4.address }}:4242</td>
  <td class="port">4242</td>
</tr>
<tr>
  <td>Meshtastic TCP API</td>
  <td>tcp://{{ ansible_default_ipv4.address }}:4403</td>
  <td class="port">4403</td>
</tr>
<tr>
  <td>Samba</td>
  <td>\\{{ ansible_default_ipv4.address }}\shared</td>
  <td class="port">445</td>
</tr>
<tr>
  <td>SSH</td>
  <td>ssh pi@{{ ansible_default_ipv4.address }}</td>
  <td class="port">{{ ssh_port }}</td>
</tr>
</tbody>
</table>

<footer>
Generated by Ansible · {{ ansible_managed }}
</footer>
</body>
</html>
