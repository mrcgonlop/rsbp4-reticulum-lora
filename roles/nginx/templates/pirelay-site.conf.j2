# {{ ansible_managed }}
# PiRelay reverse proxy — all services behind TLS

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name {{ domain }} {{ hostname }};
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    http2 on;
    server_name {{ domain }} {{ hostname }};

{% if tls_mode == "self-signed" %}
    ssl_certificate /etc/nginx/ssl/pirelay.crt;
    ssl_certificate_key /etc/nginx/ssl/pirelay.key;
{% elif tls_mode == "letsencrypt" %}
    ssl_certificate /etc/letsencrypt/live/{{ domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ domain }}/privkey.pem;
{% endif %}

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # --- Cockpit (root path) ---
    location / {
        proxy_pass http://{{ cockpit_bind_address }}:{{ cockpit_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (required by Cockpit). $connection_upgrade is
        # defined by the map in nginx.conf and resolves to "upgrade" only
        # when the client actually requests a WebSocket handshake.
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;

        # Cockpit uses long-lived streams; disable buffering and extend
        # the read timeout so idle sessions don't get killed.
        proxy_buffering off;
        proxy_read_timeout 90m;
    }

    # --- Gitea ---
    location /gitea/ {
        proxy_pass http://127.0.0.1:{{ gitea_http_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

{% if meshtastic_enable | bool %}
    # --- Meshtastic Web UI ---
    location /meshtastic/ {
        proxy_pass http://127.0.0.1:{{ meshtastic_web_port }}/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Meshtastic web client uses WebSocket for live updates
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }
{% endif %}
}
