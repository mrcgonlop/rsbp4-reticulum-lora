# {{ ansible_managed }}
# Wi-Fi HaLow (802.11ah) AP configuration

interface=halow0
driver=nl80211
ssid={{ halow_ssid | default(hostname + '-halow') }}
hw_mode=a
channel=1
wmm_enabled=0
macaddr_acl=0
auth_algs=1
wpa=2
wpa_passphrase={{ halow_psk | default('changeme12345') }}
wpa_key_mgmt=WPA-PSK
wpa_pairwise=CCMP
rsn_pairwise=CCMP
