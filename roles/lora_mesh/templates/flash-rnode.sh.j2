#!/usr/bin/env bash
# {{ ansible_managed }}
# Flash a USB-connected RNode device (e.g. LilyGO T-Beam) with RNode firmware.
# Run once after plugging in the device for the first time.

set -euo pipefail

PORT="${1:-{{ rnode_port }}}"

echo "=== RNode Firmware Flash ==="
echo "Target serial port: ${PORT}"
echo
echo "Make sure the T-Beam (or other RNode-capable board) is plugged in"
echo "via USB and visible at ${PORT}. If it shows up at a different path"
echo "(e.g. /dev/ttyACM0), pass it as the first argument to this script."
echo

if [[ ! -e "${PORT}" ]]; then
    echo "ERROR: ${PORT} does not exist. Plug in the device or pass the" >&2
    echo "correct path: $0 /dev/ttyACM0" >&2
    exit 1
fi

# Prefer the console-script shim; fall back to the Python module so this
# script survives pip entry-point weirdness (e.g. if rnodeconf's shim was
# clobbered by an earlier uninstall but RNS.Utilities.rnodeconf is still
# importable).
if command -v rnodeconf >/dev/null 2>&1; then
    RNODECONF=(rnodeconf)
elif python3 -c "import RNS.Utilities.rnodeconf" 2>/dev/null; then
    RNODECONF=(python3 -m RNS.Utilities.rnodeconf)
else
    echo "ERROR: rnodeconf is not available. Reinstall rns:" >&2
    echo "  sudo pip install --force-reinstall --no-deps rns --break-system-packages" >&2
    exit 1
fi

echo "Starting RNode auto-install on ${PORT}..."
"${RNODECONF[@]}" "${PORT}" --autoinstall

echo
echo "Flash complete. Verify with: ${RNODECONF[*]} ${PORT} --info"
