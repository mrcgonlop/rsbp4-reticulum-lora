#!/usr/bin/env bash
# {{ ansible_managed }}
# Reset the SX1262 LoRa HAT via GPIO {{ sx1262_reset_gpio }}.
#
# Uses the `pinctrl` tool (preinstalled on Raspberry Pi OS Bookworm).
# The legacy /sys/class/gpio sysfs interface was removed in Linux 6.x.

set -euo pipefail

RESET_PIN={{ sx1262_reset_gpio }}

pinctrl set "${RESET_PIN}" op dl     # output, drive low  — assert reset
sleep 0.1
pinctrl set "${RESET_PIN}" op dh     # output, drive high — release reset
sleep 0.1

echo "SX1262 reset complete (GPIO ${RESET_PIN})"
